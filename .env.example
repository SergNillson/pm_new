# Gap Certainty Strategy - Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# OPTIONAL: Only needed for LIVE trading mode
# For DRY-RUN mode, you can leave this file empty!
# =============================================================================

# Option 1: Polymarket Builder API (Recommended)
# Apply at: https://polymarket.com/settings?tab=builder
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# Option 2: Polymarket Session Token
# Get from browser DevTools → Application → Cookies
POLYMARKET_SESSION_TOKEN=

# Option 3: Private Key (requires wallet)
POLY_PRIVATE_KEY=
POLY_SAFE_ADDRESS=

# =============================================================================
# Optional: Custom RPC/CLOB endpoints
# =============================================================================
POLY_CLOB_HOST=https://clob.polymarket.com
BINANCE_API_URL=https://api.binance.com
